<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="NetMana.App"
             xmlns:local="using:NetMana"
             x:DataType="local:App"
             RequestedThemeVariant="Default">
             
    <TrayIcon.Icons>
        <TrayIcons>
            <!-- Compiled bindings now explicitly know to look inside App.axaml.cs -->
            <TrayIcon Icon="/Assets/avalonia-logo.ico" 
                      ToolTipText="My Awesome Avalonia App"
                      Command="{Binding ShowWindowCommand}">
                <TrayIcon.Menu>
                    <NativeMenu>
                        <NativeMenuItem Header="Open Main Window" 
                                        Command="{Binding ShowWindowCommand}" />
                        <NativeMenuItem Header="Settings" 
                                        Command="{Binding OpenSettingsCommand}" />
                        
                        <NativeMenuItemSeparator />
                        
                        <NativeMenuItem Header="Quit" 
                                        Command="{Binding QuitCommand}" />
                    </NativeMenu>
                </TrayIcon.Menu>
            </TrayIcon>
        </TrayIcons>
    </TrayIcon.Icons>
    
    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>
  
    <Application.Styles>
        <FluentTheme />
    </Application.Styles>
</Application>